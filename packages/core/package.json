{
  "name": "@ps1ui/core",
  "version": "0.0.0",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm check && pnpm build:js && pnpm build:css",
    "build:js": "tsdown",
    "build:css": "postcss src/styles/index.css -o dist/styles.css",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "pnpm typecheck && pnpm check:palette",
    "check:palette": "node scripts/check-palette-sync.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.2",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "playwright": "1.61.1",
    "postcss": "8.5.16",
    "postcss-cli": "11.0.1",
    "postcss-import": "16.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.5.0",
    "tsdown": "0.22.4",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vitest-browser-react": "2.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
