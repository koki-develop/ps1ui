{
  "name": "@ps1ui/site",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pnpm build:storybook",
    "build:storybook": "STORYBOOK_BASE_PATH=/ps1ui/storybook/ pnpm --filter @ps1ui/core exec storybook build -o ../site/dist/storybook",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck"
  },
  "dependencies": {
    "@ps1ui/core": "workspace:*",
    "@astrojs/react": "6.0.1",
    "astro": "7.0.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2"
  }
}
