---
import { Button, CodeBlock, Container, Heading, Stack, Text } from "@ps1ui/core";
import BaseLayout from "../layouts/BaseLayout.astro";
import { CONTAINER_PX, INSTALL_COMMAND } from "../lib/site";
import { href } from "../lib/url";
---

<BaseLayout>
  <Container size="lg" px={CONTAINER_PX}>
    <Stack direction="column" gap={{ base: "xl", md: "2xl" }} align="start">
      <Stack direction="column" gap={{ base: "md", md: "lg" }} align="start">
        <Heading level={1} size={{ base: "2xl", md: "3xl" }}>PS1 UI</Heading>
        <Text size={{ base: "md", md: "lg" }} variant="muted">
          For engineers who never left the terminal.
        </Text>
      </Stack>
      <CodeBlock language="bash" code={INSTALL_COMMAND} />
      <Stack direction="row" gap="sm" wrap>
        <Button as="a" href={href("getting-started/")}>Get Started</Button>
        <Button as="a" variant="secondary" href={href("components/")}>
          Components
        </Button>
      </Stack>
    </Stack>
  </Container>
</BaseLayout>
