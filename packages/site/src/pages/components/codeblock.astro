---
import { CodeBlock, Heading, Stack, Text } from "@ps1ui/core";
import ComponentPage from "../../layouts/ComponentPage.astro";
import Demo from "../../components/Demo.astro";

const tsSource = `type Deploy = {
  target: "staging" | "production";
  dryRun?: boolean;
};

export async function deploy({ target, dryRun = false }: Deploy) {
  if (dryRun) return plan(target);
  return apply(target);
}`;

const tsUsage = `<CodeBlock language="typescript" code={source} />`;
---

<ComponentPage slug="codeblock">
  <Demo title="Syntax highlighting" code={tsUsage}>
    <CodeBlock language="typescript" code={tsSource} />
  </Demo>

  <Stack direction="column" gap="md">
    <Heading level={2} size="lg">Languages</Heading>
    <Text>
      Ships with 40+ Prism grammars registered — the refractor common set
      (bash, css, go, json, python, rust, sql, typescript, yaml, …) plus a
      curated extra layer (dart, docker, graphql, jsx, nginx, powershell,
      shell-session, toml, tsx, zig). Unknown languages fall back to
      unhighlighted text.
    </Text>
  </Stack>
</ComponentPage>
