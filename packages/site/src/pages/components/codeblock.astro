---
import { Code, CodeBlock, Heading, Stack, Text } from "@ps1ui/core";
import ComponentPage from "../../layouts/ComponentPage.astro";
import Demo from "../../components/Demo.astro";

const tsSource = `type Deploy = {
  target: "staging" | "production";
  dryRun?: boolean;
};

export async function deploy({ target, dryRun = false }: Deploy) {
  if (dryRun) return plan(target);
  return apply(target);
}`;

const tsUsage = `<CodeBlock language="typescript" code={source} />`;

// Kept as data so the prose in the Text below stays one editable unit and
// oxfmt can't split each <Code> tag mid-attribute. Sync with
// packages/core/src/components/CodeBlock/refractor.ts's KNOWN_LANGS if the
// registered set changes.
const COMMON = ["bash", "css", "go", "json", "python", "rust", "sql", "typescript", "yaml"];
const EXTRA = [
  "dart",
  "docker",
  "graphql",
  "jsx",
  "nginx",
  "powershell",
  "shell-session",
  "toml",
  "tsx",
  "zig",
];
---

<ComponentPage slug="codeblock">
  <Demo title="Syntax highlighting" code={tsUsage}>
    <CodeBlock language="typescript" code={tsSource} />
  </Demo>

  <Stack direction="column" gap="md">
    <Heading level={2} size="lg">Languages</Heading>
    <Text>
      Ships with 40+ Prism grammars registered — the refractor common set (
      {
        COMMON.map((lang, i) => (
          <Fragment>
            {i > 0 ? ", " : null}
            <Code>{lang}</Code>
          </Fragment>
        ))
      }, …) plus a curated extra layer (
      {
        EXTRA.map((lang, i) => (
          <Fragment>
            {i > 0 ? ", " : null}
            <Code>{lang}</Code>
          </Fragment>
        ))
      }). Unknown languages fall back to unhighlighted text.
    </Text>
  </Stack>
</ComponentPage>
