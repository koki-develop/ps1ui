---
import { Checkbox, Input, Label, Stack } from "@ps1ui/core";
import ComponentPage from "../../layouts/ComponentPage.astro";
import Demo from "../../components/Demo.astro";

const withInput = `<Label htmlFor="username">Username</Label>
<Input id="username" placeholder="koki" />`;

const withCheckbox = `<Stack direction="row" gap="sm" align="center">
  <Checkbox id="notify" />
  <Label htmlFor="notify">Send me notifications</Label>
</Stack>`;
---

<ComponentPage slug="label">
  <Demo title="With an input" code={withInput}>
    <Stack direction="column" gap="sm" align="start">
      <Label htmlFor="username">Username</Label>
      <Input id="username" placeholder="koki" />
    </Stack>
  </Demo>

  <Demo title="With a checkbox" code={withCheckbox}>
    <Stack direction="row" gap="sm" align="center">
      <Checkbox id="notify" />
      <Label htmlFor="notify">Send me notifications</Label>
    </Stack>
  </Demo>
</ComponentPage>
