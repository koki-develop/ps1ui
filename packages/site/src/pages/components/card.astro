---
import { Card, Grid, Heading, Stack, Text } from "@ps1ui/core";
import ComponentPage from "../../layouts/ComponentPage.astro";
import Demo from "../../components/Demo.astro";

const basic = `<Card>
  <Stack direction="column" gap="sm">
    <Heading level={3} size="md">deploy.log</Heading>
    <Text variant="muted">Group related content on a bordered surface.</Text>
  </Stack>
</Card>`;

const grid = `<Grid columns={{ base: 1, md: 3 }} gap="md">
  <Card>
    <Text variant="muted">01</Text>
  </Card>
  <Card>
    <Text variant="muted">02</Text>
  </Card>
  <Card>
    <Text variant="muted">03</Text>
  </Card>
</Grid>`;
---

<ComponentPage slug="card">
  <Demo title="Basic" code={basic}>
    <Card>
      <Stack direction="column" gap="sm">
        <Heading level={3} size="md">deploy.log</Heading>
        <Text variant="muted">Group related content on a bordered surface.</Text>
      </Stack>
    </Card>
  </Demo>

  <Demo title="In a grid" code={grid}>
    <Grid columns={{ base: 1, md: 3 }} gap="md">
      <Card>
        <Text variant="muted">01</Text>
      </Card>
      <Card>
        <Text variant="muted">02</Text>
      </Card>
      <Card>
        <Text variant="muted">03</Text>
      </Card>
    </Grid>
  </Demo>
</ComponentPage>
