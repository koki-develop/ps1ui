---
import { Code, CodeBlock, Heading, Stack, Text } from "@ps1ui/core";
import ComponentPage from "../../layouts/ComponentPage.astro";

const usage = `import { PS1Root } from "@ps1ui/core";

export function App() {
  return (
    <PS1Root>
      {/* your app */}
    </PS1Root>
  );
}`;
---

<ComponentPage slug="ps1root">
  <Stack direction="column" gap="md">
    <Heading level={2} size="lg">Usage</Heading>
    <Text>
      Wrap your app in <Code>PS1Root</Code> once, at the top of the tree. Responsive props on
      descendant components resolve against it — without a <Code>PS1Root</Code> ancestor they
      silently fall back to their <Code>base</Code> values.
    </Text>
    <CodeBlock language="tsx" code={usage} />
  </Stack>
</ComponentPage>
