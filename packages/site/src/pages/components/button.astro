---
import { Button, Stack, Text } from "@ps1ui/core";
import ComponentPage from "../../layouts/ComponentPage.astro";
import Demo from "../../components/Demo.astro";

const variants = `<Button variant="primary">Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="danger">Danger</Button>`;

const sizes = `<Button size="sm">Small</Button>
<Button size="md">Medium</Button>
<Button size="lg">Large</Button>`;

const disabled = `<Button disabled>Primary</Button>
<Button variant="secondary" disabled>Secondary</Button>
<Button variant="danger" disabled>Danger</Button>`;

const asLink = `<Button as="a" href="https://github.com/koki-develop/ps1ui">
  View on GitHub
</Button>`;
---

<ComponentPage slug="button">
  <Demo title="Variants" code={variants}>
    <Stack direction="row" gap="md" wrap>
      <Button variant="primary">Primary</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="danger">Danger</Button>
    </Stack>
  </Demo>

  <Demo title="Sizes" code={sizes}>
    <Stack direction="row" gap="md" align="center" wrap>
      <Button size="sm">Small</Button>
      <Button size="md">Medium</Button>
      <Button size="lg">Large</Button>
    </Stack>
  </Demo>

  <Demo title="Disabled" code={disabled}>
    <Stack direction="row" gap="md" wrap>
      <Button disabled>Primary</Button>
      <Button variant="secondary" disabled>Secondary</Button>
      <Button variant="danger" disabled>Danger</Button>
    </Stack>
  </Demo>

  <Demo title="As a link" code={asLink}>
    <Button as="a" href="https://github.com/koki-develop/ps1ui">
      View on GitHub
    </Button>
  </Demo>

  <Text variant="muted">
    On the native button element, type defaults to "button" — a Button inside a form never
    submits implicitly. Pass type="submit" explicitly when the button should submit.
  </Text>
</ComponentPage>
