---
import { Input, Label, Stack } from "@ps1ui/core";
import ComponentPage from "../../layouts/ComponentPage.astro";
import Demo from "../../components/Demo.astro";

const basic = `<Input placeholder="~/projects" />`;

const disabled = `<Input placeholder="~/projects" disabled />`;

const withLabel = `<Label htmlFor="hostname">Hostname</Label>
<Input id="hostname" placeholder="localhost" />`;
---

<ComponentPage slug="input">
  <Demo title="Basic" code={basic}>
    <Input placeholder="~/projects" />
  </Demo>

  <Demo title="Disabled" code={disabled}>
    <Input placeholder="~/projects" disabled />
  </Demo>

  <Demo title="With a label" code={withLabel}>
    <Stack direction="column" gap="sm" align="start">
      <Label htmlFor="hostname">Hostname</Label>
      <Input id="hostname" placeholder="localhost" />
    </Stack>
  </Demo>
</ComponentPage>
