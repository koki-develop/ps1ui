---
import "@ps1ui/core/styles.css";
import { PS1Root } from "@ps1ui/core";
// Same file the core stylesheet's @font-face references — the ?url import
// resolves to the identical hashed asset, so preloading it starts the font
// download as soon as the HTML arrives instead of after CSS parse. This is
// what suppresses the first-visit FOUT (font-display: swap flicker). Latin is
// the only subset this English-only site renders above the fold.
import jetbrainsMonoLatinUrl from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = "For engineers who never left the terminal." } =
  Astro.props;

// Pages pass a short title ("Button", "Getting Started"); the site suffix is
// composed here once so no call site carries " — PS1 UI" itself.
const fullTitle = title ? `${title} — PS1 UI` : "PS1 UI";

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    {/* crossorigin is required even same-origin: font requests use CORS mode,
        and a preload without it is ignored (the font gets fetched twice). */}
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={jetbrainsMonoLatinUrl}
      crossorigin
    />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <title>{fullTitle}</title>
  </head>
  <body>
    <PS1Root className="site-root">
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </PS1Root>
  </body>
</html>

<style>
  /* PS1Root is a React component, so Astro's scoped attribute never lands on
     it — target its className globally. Flex column + min-height pins the
     footer to the bottom on short pages. */
  :global(.site-root) {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  main {
    flex: 1;
    padding-block: clamp(2rem, 6vw, 4rem);
  }
</style>
