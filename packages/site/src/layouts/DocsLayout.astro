---
import { Container, Details } from "@ps1ui/core";
import BaseLayout from "./BaseLayout.astro";
import SidebarNav from "../components/SidebarNav.astro";
import { CONTAINER_PX } from "../lib/site";

interface Props {
  title: string;
  description?: string;
  current?: string;
}

const { title, description, current } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Container size="xl" px={CONTAINER_PX}>
    <div class="docs">
      {/*
        Two sidebar variants, CSS-swapped at 48rem. Rendering both is
        cheaper than reaching for JS to conditionally hydrate — the mobile
        <Details> would otherwise need client-side state to swap in.
        `display: none` removes the hidden variant from the a11y tree, so
        AT users only see the visible surface.

        The mobile variant deliberately has NO <nav aria-label="Components">
        wrapper: the <Details summary="Components"> disclosure is itself
        the labeled control, so wrapping in a same-name landmark would
        double-announce "Components" for screen-reader users AND — if the
        display:none swap fails (CSS load delay, reader-mode extensions) —
        would leave two identical "Components" landmarks visible at once.
        Only the desktop variant is a nav landmark; the mobile disclosure
        stands alone.
      */}
      <div class="sidebar sidebar--mobile">
        <Details summary="Components">
          <SidebarNav current={current} />
        </Details>
      </div>
      <nav class="sidebar sidebar--desktop" aria-label="Components">
        <SidebarNav current={current} />
      </nav>
      <div class="content">
        <slot />
      </div>
    </div>
  </Container>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ps1ui-space-2xl);
  }

  .sidebar--desktop {
    display: none;
  }

  .content {
    min-width: 0;
  }

  /* Threshold mirrors --ps1ui-breakpoint-md in @ps1ui/core's tokens.css —
     @media conditions can't use var() per the CSS spec. Keep in sync. */
  @media (min-width: 48rem) {
    .docs {
      grid-template-columns: 11rem minmax(0, 1fr);
    }

    .sidebar--mobile {
      display: none;
    }

    .sidebar--desktop {
      display: block;
      position: sticky;
      top: var(--ps1ui-space-2xl);
      align-self: start;
    }
  }
</style>
