---
import { Anchor, Container, Stack, Text } from "@ps1ui/core";
import BaseLayout from "./BaseLayout.astro";
import { COMPONENT_GROUPS } from "../lib/components";
import { CONTAINER_PX } from "../lib/site";
import { href } from "../lib/url";

interface Props {
  title: string;
  description?: string;
  current?: string;
}

const { title, description, current } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Container size="xl" px={CONTAINER_PX}>
    <div class="docs">
      <nav class="sidebar" aria-label="Components">
        <Stack direction="column" gap="lg">
          {
            COMPONENT_GROUPS.map((group) => (
              <Stack direction="column" gap="sm">
                <Text as="span" size="xs" variant="subtle" weight="semibold">
                  {group.title}
                </Text>
                <ul>
                  {group.items.map((c) => (
                    <li>
                      <Anchor
                        href={href(`components/${c.slug}/`)}
                        variant={c.slug === current ? "primary" : "subtle"}
                        aria-current={c.slug === current ? "page" : undefined}
                      >
                        {c.name}
                      </Anchor>
                    </li>
                  ))}
                </ul>
              </Stack>
            ))
          }
        </Stack>
      </nav>
      <div class="content">
        <slot />
      </div>
    </div>
  </Container>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ps1ui-space-2xl);
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ps1ui-space-xs) var(--ps1ui-space-md);
    font-size: var(--ps1ui-font-size-sm);
  }

  .content {
    min-width: 0;
  }

  /* Threshold mirrors --ps1ui-breakpoint-md in @ps1ui/core's tokens.css —
     @media conditions can't use var() per the CSS spec. Keep in sync. */
  @media (min-width: 48rem) {
    .docs {
      grid-template-columns: 11rem minmax(0, 1fr);
    }

    .sidebar {
      position: sticky;
      top: var(--ps1ui-space-2xl);
      align-self: start;
    }

    ul {
      flex-direction: column;
      flex-wrap: nowrap;
      gap: var(--ps1ui-space-xs);
    }
  }
</style>
